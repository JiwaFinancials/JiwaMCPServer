using System.ComponentModel;
using JiwaMcpServer.Services;
using ModelContextProtocol.Server;

namespace JiwaMcpServer.Tools;

[McpServerToolType]
public class CustomerTools(JiwaApiClient apiClient) : JiwaToolBase(apiClient)
{
    [McpServerTool, Description("Search for customers by name or code.")]
    public async Task<string> SearchCustomers(
        [Description("Customer name or debtor code to search for.")] string query,
        CancellationToken ct = default)
    {
        var result = await ApiClient.GetAsync(
            $"/api/v2/Debtors?DebtorName={Uri.EscapeDataString(query)}", ct);
        return result.ToString();
    }

    [McpServerTool, Description("Get full details for a customer by their Jiwa Debtor ID.")]
    public async Task<string> GetCustomer(
        [Description("The Jiwa Debtor GUID (e.g. ABC0000001).")] string debtorId,
        CancellationToken ct = default)
    {
        var result = await ApiClient.GetAsync($"/api/v2/Debtors/{Uri.EscapeDataString(debtorId)}", ct);
        return result.ToString();
    }

    [McpServerTool, Description("Retrieve outstanding transactions (invoices/credits) for a customer.")]
    public async Task<string> GetCustomerTransactions(
        [Description("The Jiwa Debtor GUID.")] string debtorId,
        CancellationToken ct = default)
    {
        var result = await ApiClient.GetAsync(
            $"/api/v2/Debtors/{Uri.EscapeDataString(debtorId)}/Transactions", ct);
        return result.ToString();
    }
}
