using JiwaMcpServer.Services;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Hosting;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.EventLog;
using System.Diagnostics;

var builder = Host.CreateApplicationBuilder(args);

builder.Logging.AddConsole(options =>
{
    options.LogToStandardErrorThreshold = LogLevel.Trace;
});

// Also log to Windows Event Log (Application) using a dedicated source.
// Note: creating an event source may require administrative privileges the first time.
builder.Logging.AddEventLog(options =>
{
    options.SourceName = "JiwaMcpServer";
    options.LogName = "Application";
});

// Try to ensure the Event Log source exists on Windows. Creating the source requires
// administrative privileges the first time; if creation fails we write a friendly
// message to the console and continue so the app still runs.
if (OperatingSystem.IsWindows())
{
    var eventSource = "JiwaMcpServer";
    var logName = "Application";
    try
    {
        if (!EventLog.SourceExists(eventSource))
        {
            Console.WriteLine($"Event source '{eventSource}' not found. Attempting to create it (requires admin)...");
            EventLog.CreateEventSource(eventSource, logName);
            Console.WriteLine($"Event source '{eventSource}' created successfully.");
        }
    }
    catch (Exception ex)
    {
        // Avoid throwing — just inform the user. Event logging may fail without proper permissions.
        Console.WriteLine($"Could not create event source '{eventSource}': {ex.Message}. Continuing without creating the source.");
    }
}

// Register Jiwa API client
// Register HTTP logging handler and Jiwa API client
builder.Services.AddTransient<HttpLoggingHandler>();
builder.Services.AddHttpClient<JiwaApiClient>(client =>
{
    // Use a valid absolute URI for the API base address
    client.BaseAddress = new Uri("https://api.jiwa.com.au");
    client.DefaultRequestHeaders.Add("Accept", "application/json");
})
    .AddHttpMessageHandler<HttpLoggingHandler>();

// Retrieve credentials from environment variables
builder.Services.AddSingleton<JiwaApiClient>(sp =>
{
    var httpClientFactory = sp.GetRequiredService<IHttpClientFactory>();
    var logger = sp.GetRequiredService<ILogger<JiwaApiClient>>();
    var httpClient = httpClientFactory.CreateClient(nameof(JiwaApiClient));

    var username = Environment.GetEnvironmentVariable("JIWA_USERNAME")
        ?? throw new InvalidOperationException("JIWA_USERNAME environment variable is not set.");
    var password = Environment.GetEnvironmentVariable("JIWA_PASSWORD")
        ?? throw new InvalidOperationException("JIWA_PASSWORD environment variable is not set.");

    return new JiwaApiClient(httpClient, logger, username, password);
});

// Register MCP server with stdio transport and auto-discover tools
builder.Services
    .AddMcpServer()
    .WithStdioServerTransport()
    .WithToolsFromAssembly();

await builder.Build().RunAsync();
